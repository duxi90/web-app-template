{
  "version": "0.2",
  "language": "en",
  "dictionaries": [
    "en_US",
    "typescript",
    "node",
    "html",
    "css",
    "npm",
    "softwareTerms",
    "fullstack",
    "markdown",
    "shell",
    "project-terms"
  ],
  "import": [
    "@cspell/dict-fullstack/cspell-ext.json",
    "@cspell/dict-markdown/cspell-ext.json",
    "@cspell/dict-shell/cspell-ext.json"
  ],
  "dictionaryDefinitions": [
    { "name": "project-terms", "path": "./.cspell/project-terms.txt", "addWords": true }
  ],
  "ignorePaths": [
    "node_modules/**",
    ".next/**",
    ".turbo/**",
    ".velite/**",
    "out/**",
    "public/**",
    "bun.lock",
    "*.tsbuildinfo"
  ],
  "ignoreRegExpList": ["Urls", "Email", "HexValues", "Base64"]
}
