{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": [
    "next",
    "next-intl",
    "tailwindcss",
    "@tailwindcss/postcss",
    "@repo/config-typescript",
    "@repo/config-tailwind",
    "@repo/ui",
    "@acme/config-typescript",
    "@acme/config-tailwind",
    "@acme/ui",
    "@commitlint/cli",
    "lint-staged",
    "@cloudflare/workers-types",
    "@opennextjs/cloudflare",
    "wrangler"
  ],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts"],
      "project": ["scripts/**/*.ts"]
    },
    "apps/*": {
      "entry": [
        "next.config.ts",
        "next-env.d.ts",
        "open-next.config.ts",
        "wrangler.toml",
        "src/index.ts",
        "app/**/page.{ts,tsx}",
        "app/**/layout.{ts,tsx}",
        "app/**/route.ts",
        "app/**/loading.tsx",
        "app/**/not-found.tsx",
        "app/**/error.tsx"
      ]
    },
    "packages/ui": {
      "entry": ["src/index.ts", "src/components/**/*.tsx"]
    },
    "packages/content": {
      "entry": ["src/index.ts", "velite.config.ts"]
    },
    "packages/config-*": {
      "entry": ["*.{json,mjs,ts,css}"],
      "project": ["*.{json,mjs,ts,css}"]
    }
  }
}
