{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Next.js app",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ES2023"],
    "jsx": "preserve",
    "noEmit": true,
    "allowJs": false,
    "incremental": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "plugins": [{ "name": "next" }]
  }
}
